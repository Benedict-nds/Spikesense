# Copy to .env and adjust. Used by the Expo app (root) only.
# Backend has its own .env in backend/

# Required when running the app on a physical device (Expo Go on your phone).
# Replace with your computer's LAN IP so the phone can reach the backend.
# Find IP: Mac = System Settings > Network; Windows = ipconfig
# EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api
